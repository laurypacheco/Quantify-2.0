# ============================================================
#  .env.playwright — credenciales y URL del ambiente bajo prueba
#  Copia de .env.playwright.example creada por el instalador.
#  ⚠️ Este archivo está gitignored — NUNCA lo subas al repo.
# ============================================================

# URL base de la aplicación (playwright.config.ts la lee como baseURL)
BASE_URL=https://app.tu-empresa.com

# Credenciales por usuario — una pareja por cada usuario/rol que usen los tests.
# El sufijo es el nombre LITERAL del usuario en mayúsculas (lo define el usuario, nunca se inventa).
# Ej.: usuario "jperez" → TEST_USER_JPEREZ / TEST_PASS_JPEREZ
TEST_USER_EJEMPLO=
TEST_PASS_EJEMPLO=

# Velocidad de ejecución para verificación visual (ms por acción; 0 = normal)
SLOW_MO=0

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "selector-cache",
  "description": "Cache de selectores por dominio de app. Generado por discovery agent. Evita re-explorar pantallas ya catalogadas.",
  "type": "object",
  "required": ["domain", "last_updated"],
  "properties": {
    "domain": { "type": "string", "description": "Dominio de la app (sin protocolo ni path)", "example": "app.company.com" },
    "last_updated": { "type": "string", "format": "date-time" },
    "technology": { "type": "string", "enum": ["webforms", "react", "vue", "angular", "unknown"] },
    "wait_strategy": { "type": "string", "enum": ["A", "B", "C"] },
    "screens": {
      "type": "object",
      "description": "Mapa de nombre_pantalla → selectores. Misma estructura que discovery-output.json screens[].selectors",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "last_verified": { "type": "string", "format": "date-time" },
          "needs_refresh": { "type": "boolean", "default": false },
          "selectors": { "type": "object" }
        }
      }
    }
  }
}

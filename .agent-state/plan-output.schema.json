{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "plan-output",
  "description": "Plan estructurado de un TC generado por el tc-reader agent. Input para discovery y code-builder.",
  "type": "object",
  "required": ["session_id", "tc_id", "title", "steps"],
  "properties": {
    "session_id": { "type": "string" },
    "tc_id": { "type": "integer" },
    "title": { "type": "string" },
    "module": { "type": ["string", "null"] },
    "area_path": { "type": ["string", "null"] },
    "priority": { "type": ["integer", "null"] },
    "url": { "type": ["string", "null"], "description": "URL de inicio del flujo. null si no está en el TC." },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["PRECOND_0", "PRECOND_1", "PRECOND_3"] },
          "description": { "type": ["string", "null"] },
          "user": { "type": ["string", "null"] },
          "role": { "type": ["string", "null"] },
          "portal": { "type": ["string", "null"] },
          "module": { "type": ["string", "null"] }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "action"],
        "properties": {
          "id": { "type": "integer" },
          "action": { "type": "string" },
          "expected": { "type": ["string", "null"] },
          "type": { "type": "string", "enum": ["action", "validate"] }
        }
      }
    },
    "test_data": {
      "type": "object",
      "description": "Valores de prueba extraídos del TC o de LocalDataSource"
    },
    "files_needed": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "path": { "type": ["string", "null"] }
        }
      }
    },
    "variants": {
      "type": "array",
      "description": "IDs de TCs variantes (validaciones, errores) relacionados con este TC",
      "items": { "type": "integer" }
    }
  },
  "example": {
    "session_id": "2026-04-12-9400",
    "tc_id": 9400,
    "title": "AutoReg-Preventas | Procesar Excel válido — Happy Path",
    "module": "Preventas",
    "area_path": "AUTOREG\\Preventas\\Procesamiento Excel",
    "priority": 2,
    "url": "https://tu-app.com/preventas",
    "preconditions": [
      { "type": "PRECOND_3", "user": "graciagc", "role": "CASE CREATOR", "portal": "AutoReg", "module": "Preventas" }
    ],
    "steps": [
      { "id": 1, "action": "Navegar a Procesamiento Preventas Excel", "expected": "Se muestra la pantalla de carga", "type": "action" },
      { "id": 2, "action": "Adjuntar archivo Excel válido", "expected": "Archivo cargado correctamente", "type": "action" },
      { "id": 3, "action": "Hacer click en Procesar", "expected": "Se muestra número de lote generado", "type": "validate" }
    ],
    "test_data": { "user": "graciagc", "password": null },
    "files_needed": [{ "description": "Archivo Excel de prueba con preventas", "path": null }],
    "variants": []
  }
}

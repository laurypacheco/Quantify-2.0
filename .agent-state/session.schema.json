{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "session",
  "description": "Estado del pipeline completo para una sesión de automatización E2E",
  "type": "object",
  "required": ["session_id", "created", "org", "project", "scenario", "tcs"],
  "properties": {
    "session_id": {
      "type": "string",
      "description": "Identificador único de sesión. Formato: YYYY-MM-DD-NNN",
      "example": "2026-04-12-001"
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp de creación ISO 8601"
    },
    "org": {
      "type": "string",
      "description": "Organización de Azure DevOps",
      "example": "AutoregPR"
    },
    "project": {
      "type": "string",
      "description": "Proyecto de Azure DevOps",
      "example": "AUTOREG"
    },
    "test_plan": {
      "type": ["integer", "null"],
      "description": "ID del Test Plan en ADO"
    },
    "test_suite": {
      "type": ["integer", "null"],
      "description": "ID del Test Suite en ADO"
    },
    "url": {
      "type": "string",
      "description": "URL base de la aplicación bajo prueba"
    },
    "scenario": {
      "type": "string",
      "enum": ["A", "B"],
      "description": "A = Código Playwright completo | B = Ejecución directa sin archivos"
    },
    "tcs": {
      "type": "array",
      "description": "Lista de TCs en este pipeline",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "integer", "description": "ID del Work Item en ADO" },
          "status": {
            "type": "string",
            "enum": ["pending", "reading", "discovering", "building", "built", "running", "pass", "fail", "fixed", "needs_discovery", "reported"],
            "description": "Estado actual en el pipeline"
          },
          "phase": {
            "type": ["string", "null"],
            "description": "Último agente que procesó este TC"
          },
          "spec": {
            "type": ["string", "null"],
            "description": "Ruta relativa al spec Playwright generado"
          },
          "last_run": {
            "type": ["string", "null"],
            "enum": ["pass", "fail", null],
            "description": "Resultado de la última ejecución"
          },
          "fail_count": {
            "type": "integer",
            "default": 0,
            "description": "Número de fallos consecutivos"
          },
          "fix_applied": {
            "type": ["string", "null"],
            "description": "Descripción del fix del debugger agent"
          },
          "debug_note": {
            "type": ["string", "null"],
            "description": "Nota del debugger si requiere intervención manual"
          }
        }
      }
    }
  },
  "example": {
    "session_id": "2026-04-12-001",
    "created": "2026-04-12T10:00:00Z",
    "org": "AutoregPR",
    "project": "AUTOREG",
    "test_plan": 9361,
    "test_suite": 9363,
    "url": "https://tu-app.com",
    "scenario": "A",
    "tcs": [
      { "id": 9400, "status": "pass", "phase": "reporter", "spec": "TPlans/tests/9400-happy-path.spec.ts", "last_run": "pass", "fail_count": 0 },
      { "id": 9401, "status": "building", "phase": "code-builder", "spec": null, "last_run": null, "fail_count": 0 }
    ]
  }
}
